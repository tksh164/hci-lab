{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "6579899646675758178"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "The location for the resources."
      }
    },
    "virtualNetworkName": {
      "type": "string",
      "metadata": {
        "description": "The name of the virtual network."
      }
    }
  },
  "variables": {
    "virtualNetworkNameAddressPrefix": "192.168.0.0/16",
    "defaultSubnet": {
      "name": "default",
      "addressPrefix": "192.168.0.0/24"
    },
    "subnetNsgName": {
      "default": "[format('{0}-{1}-nsg', parameters('virtualNetworkName'), toLower(variables('defaultSubnet').name))]"
    }
  },
  "resources": {
    "res_subnetNsg": {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-07-01",
      "name": "[variables('subnetNsgName').default]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": []
      }
    },
    "res_vnet": {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-07-01",
      "name": "[parameters('virtualNetworkName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('virtualNetworkNameAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('defaultSubnet').name]",
            "properties": {
              "addressPrefix": "[variables('defaultSubnet').addressPrefix]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('subnetNsgName').default)]"
              },
              "serviceEndpoints": [
                {
                  "service": "Microsoft.KeyVault",
                  "locations": [
                    "*"
                  ]
                },
                {
                  "service": "Microsoft.Storage",
                  "locations": [
                    "*"
                  ]
                }
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "res_subnetNsg"
      ]
    }
  },
  "outputs": {
    "virtualNetworkId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
    },
    "subnetId": {
      "type": "object",
      "value": {
        "default": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), variables('defaultSubnet').name)]"
      }
    }
  }
}